generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Store {
  id            String         @id @default(cuid())
  shopDomain    String         @unique
  installedAt   DateTime       @default(now())
  uninstalledAt DateTime?
  audits        Audit[]
  entitlements  Entitlement[]
  subscriptions Subscription[]
  fixDismissals  FixDismissal[]
  ruleDismissals RuleDismissal[]
  linkScans      LinkScan[]
  pageSpeedScans PageSpeedScan[]
  backgroundJobs BackgroundJob[]

  @@index([shopDomain])
}

model Audit {
  id              String        @id @default(cuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  status          AuditStatus   @default(PENDING)
  triggeredBy     TriggerSource @default(MANUAL)
  createdAt       DateTime      @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  snapshot        Json?
  findings        Finding[]
  launchScore     Int?
  isUnlocked      Boolean       @default(false)
  unlockedAt      DateTime?
  oneTimeChargeId String?
  pdfUrl          String?
  errorMessage    String?

  @@index([storeId, completedAt])
  @@index([storeId, status])
}

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TriggerSource {
  MANUAL
  WEBHOOK_THEME_PUBLISH
  SCHEDULED_WEEKLY
}

model Finding {
  id          String   @id @default(cuid())
  auditId     String
  audit       Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  ruleId      Int
  ruleCode    String
  severity    Severity
  category    Category
  title       String
  body        String
  fixSteps    Json
  fixDeepLink String?
  evidence    Json?
  confidence  Float    @default(1.0)

  @@index([auditId, severity])
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Category {
  PAYMENTS_FRAUD
  SHIPPING_FULFILLMENT
  PRODUCT_CATALOG
  SEO_DISCOVERABILITY
  TRUST_SIGNALS
  CHECKOUT_CONVERSION
  MOBILE_THEME
}

model Entitlement {
  id        String          @id @default(cuid())
  storeId   String
  store     Store           @relation(fields: [storeId], references: [id])
  type      EntitlementType
  grantedAt DateTime        @default(now())
  expiresAt DateTime?
  chargeId  String?

  @@index([storeId, type])
}

enum EntitlementType {
  ONE_TIME_UNLOCK
  AUDIT_PLUS_MONTHLY
}

model Subscription {
  id               String    @id
  storeId          String
  store            Store     @relation(fields: [storeId], references: [id])
  status           String
  currentPeriodEnd DateTime?
  startedAt        DateTime  @default(now())
}

model FixDismissal {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fixId       String
  dismissedAt DateTime @default(now())

  @@unique([storeId, fixId])
  @@index([storeId])
}

model RuleDismissal {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ruleCode    String
  dismissedAt DateTime @default(now())

  @@unique([storeId, ruleCode])
  @@index([storeId])
}

model WebhookLog {
  id          String    @id @default(cuid())
  topic       String
  shop        String
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?
}

// Broken Link Finder (Audit Plus tool). A LinkScan crawls the storefront's
// content for dead links and broken images; each problem is a LinkIssue.
// Phase 1 is read-only/report-only — issues guide the merchant to the fix.
model LinkScan {
  id           String         @id @default(cuid())
  storeId      String
  store        Store          @relation(fields: [storeId], references: [id])
  status       LinkScanStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  pagesScanned Int            @default(0)
  linksChecked Int            @default(0)
  brokenCount  Int            @default(0)
  truncated    Boolean        @default(false)
  errorMessage String?
  issues       LinkIssue[]

  @@index([storeId, status])
  @@index([storeId, completedAt])
}

model LinkIssue {
  id             String   @id @default(cuid())
  scanId         String
  scan           LinkScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  // Where the broken link was found: product | page | blog_article | homepage
  sourceType     String
  sourceRef      String?
  sourceLabel    String
  sourceAdminUrl String?
  // The broken link/image target, and how it failed.
  url            String
  kind           String
  statusCode     Int?
  redirectChain  Int      @default(0)
  detail         String?

  @@index([scanId])
}

enum LinkScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Mobile PageSpeed Insights (Audit Plus tool). Separate from full audits so
// merchants can run Google's Lighthouse mobile score on demand.
// Postgres-backed job queue (replaces BullMQ/Redis). The worker polls only when
// idle — no always-on Redis command burn from empty queue listeners.
model BackgroundJob {
  id           String              @id @default(cuid())
  storeId      String?
  store        Store?              @relation(fields: [storeId], references: [id])
  queue        String
  payload      Json
  status       BackgroundJobStatus @default(PENDING)
  attempts     Int                 @default(0)
  maxAttempts  Int                 @default(3)
  runAfter     DateTime            @default(now())
  createdAt    DateTime            @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  @@index([status, runAfter])
  @@index([queue, status])
}

enum BackgroundJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model PageSpeedScan {
  id           String         @id @default(cuid())
  storeId      String
  store        Store          @relation(fields: [storeId], references: [id])
  status       LinkScanStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  measuredUrl  String?
  score        Int?
  errorMessage String?

  @@index([storeId, status])
  @@index([storeId, completedAt])
}

// Global admin-configurable settings (key-value store).
// Used for feature toggles that shouldn't require a code deploy:
//   promotion_active = "true" | "false"
//   promotion_ends_at = ISO date string (empty = indefinite)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
