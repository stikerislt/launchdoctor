SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_inventory,read_orders,read_locations,read_shipping,read_themes,read_content,read_online_store_pages,read_legal_policies,read_payment_terms,read_shopify_payments_payouts,read_customers,read_files,write_products,write_files,write_content
APP_URL=https://launchdoctor.app
SHOPIFY_APP_URL=https://launchdoctor.app
DATABASE_URL=postgresql://launch_doctor:launch_doctor@localhost:5432/launch_doctor
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
PDF_SIGN_SECRET=
NODE_ENV=development

# --- Production notes ---
# NODE_ENV=production
# Do not set BILLING_DEV_BYPASS in production (real Shopify Billing only works on public apps).
# BILLING_DEV_BYPASS=false
# PLAYWRIGHT_BROWSERS_PATH=0 is set in Dockerfile for worker Chromium.

# Local dev: custom apps cannot use Shopify Billing API — bypass is on by default in development.
# BILLING_DEV_BYPASS=true
