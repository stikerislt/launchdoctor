SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Must match shopify.app.toml and app/lib/shopify-scopes.ts (see docs/FIX_SCOPES.md)
SCOPES=read_content,read_files,read_inventory,read_legal_policies,read_locations,read_online_store_pages,read_orders,read_products,read_shipping,read_themes,write_content,write_files,write_inventory,write_products
# Production (Fly): https://launch-doctor.fly.dev — local dev uses CLI tunnel via `pnpm dev`
APP_URL=https://launch-doctor.fly.dev
SHOPIFY_APP_URL=https://launch-doctor.fly.dev
# Postgres — local Docker, or Supabase (see docs/SUPABASE.md)
# Supabase runtime (session pooler URI from dashboard, us-east-1 — colocated with Fly iad):
# DATABASE_URL=postgresql://postgres.mtsyykxdxabtjdcgbuwo:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
# Supabase migrations: production also uses the session pooler (direct host db.<ref>.supabase.co is IPv6-only).
# DIRECT_URL=postgresql://postgres.mtsyykxdxabtjdcgbuwo:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://launch_doctor:launch_doctor@localhost:5432/launch_doctor
DIRECT_URL=postgresql://launch_doctor:launch_doctor@localhost:5432/launch_doctor
# Background jobs use Postgres (BackgroundJob table), not Redis.
# REDIS_URL is optional/legacy — leave unset unless you still run old BullMQ workers.
# REDIS_URL=redis://localhost:6379
# Worker idle poll interval when the queue is empty (default 10s, ms):
# WORKER_IDLE_POLL_MS=10000
SENTRY_DSN=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
PDF_SIGN_SECRET=
# Google PageSpeed Insights API — mobile performance score during audits (worker + web)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
# Comma-separated admin emails for the admin panel at /app/admin
ADMIN_EMAILS=your-email@gmail.com
# Comma-separated dev store domains that always get admin access
ADMIN_STORES=your-store.myshopify.com
NODE_ENV=development

# --- Production notes ---
# NODE_ENV=production
# Do not set BILLING_DEV_BYPASS in production (real Shopify Billing only works on public apps).
# BILLING_DEV_BYPASS=false
# PLAYWRIGHT_BROWSERS_PATH=0 is set in Dockerfile for worker Chromium.

# Local dev: custom apps cannot use Shopify Billing API — bypass is on by default in development.
# BILLING_DEV_BYPASS=true
# Partner development stores are auto-detected for test charges. Force live charges in prod:
# BILLING_LIVE_CHARGES=true
# Force test charges on production hosting (e.g. staging on Fly):
# BILLING_TEST_CHARGES=true
